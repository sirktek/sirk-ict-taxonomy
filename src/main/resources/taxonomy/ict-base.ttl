# ICT Taxonomy Base Schema in RDF-S (Turtle format)
# Information & communications technology, organized under three roots:
# Hardware, Software and a logical Network grouping. Extracted from the
# machine taxonomy in 3.x.

@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix schema:  <https://schema.org/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix ict:     <http://taxonomy.sirktek.no/ict#> .
# Cross-cutting classes/properties (Manufacturer, Model, assetValue, ...)
@prefix common:  <http://taxonomy.sirktek.no/common#> .

# ===================================================================
# Root Classes
# ===================================================================

ict:Hardware a rdfs:Class ;
    rdfs:label "Hardware"@en, "Maskinvare"@no ;
    rdfs:comment "Physical IT hardware: computers, network devices and peripherals"@en .

ict:Software a rdfs:Class ;
    rdfs:label "Software"@en, "Programvare"@no ;
    rdfs:comment "Software assets: applications, operating systems and licenses"@en .

# Logical network grouping (NOT a device — that is ict:NetworkEquipment under
# Hardware). Tenants create org-specific subcategories here (e.g. "HQ Network")
# that equipment belongs to, documenting layout/subnets in one place.
ict:Network a rdfs:Class ;
    rdfs:label "Network"@en, "Nettverk"@no ;
    rdfs:comment "A logical network grouping: an org-specific network that equipment belongs to"@en .

# ===================================================================
# Hardware subcategories
# ===================================================================

ict:Computer a rdfs:Class ;
    rdfs:subClassOf ict:Hardware ;
    rdfs:label "Computer"@en, "Datamaskin"@no ;
    rdfs:comment "Computers including desktops, laptops and servers"@en .

ict:Desktop a rdfs:Class ;
    rdfs:subClassOf ict:Computer ;
    rdfs:label "Desktop"@en, "Stasjonær PC"@no ;
    rdfs:comment "Desktop/workstation computer"@en .

ict:Laptop a rdfs:Class ;
    rdfs:subClassOf ict:Computer ;
    rdfs:label "Laptop"@en, "Bærbar PC"@no ;
    rdfs:comment "Portable laptop computer"@en .

ict:Server a rdfs:Class ;
    rdfs:subClassOf ict:Computer ;
    rdfs:label "Server"@en, "Server"@no ;
    rdfs:comment "Server computer"@en .

ict:NetworkEquipment a rdfs:Class ;
    rdfs:subClassOf ict:Hardware ;
    rdfs:label "Network Equipment"@en, "Nettverksutstyr"@no ;
    skos:altLabel "Networking Equipment"@en ;
    rdfs:comment "Physical networking devices: routers, switches, access points, firewalls"@en .

ict:Router a rdfs:Class ;
    rdfs:subClassOf ict:NetworkEquipment ;
    rdfs:label "Router"@en, "Ruter"@no ;
    rdfs:comment "Network router"@en .

ict:Switch a rdfs:Class ;
    rdfs:subClassOf ict:NetworkEquipment ;
    rdfs:label "Switch"@en, "Svitsj"@no ;
    rdfs:comment "Network switch"@en .

ict:AccessPoint a rdfs:Class ;
    rdfs:subClassOf ict:NetworkEquipment ;
    rdfs:label "Access Point"@en, "Aksesspunkt"@no ;
    skos:altLabel "Wireless Access Point"@en ;
    rdfs:comment "Wireless access point"@en .

ict:Firewall a rdfs:Class ;
    rdfs:subClassOf ict:NetworkEquipment ;
    rdfs:label "Firewall"@en, "Brannmur"@no ;
    rdfs:comment "Network firewall appliance"@en .

ict:Peripheral a rdfs:Class ;
    rdfs:subClassOf ict:Hardware ;
    rdfs:label "Peripheral"@en, "Tilleggsutstyr"@no ;
    rdfs:comment "Peripheral hardware such as monitors and printers"@en .

ict:Monitor a rdfs:Class ;
    rdfs:subClassOf ict:Peripheral ;
    rdfs:label "Monitor"@en, "Skjerm"@no ;
    rdfs:comment "Display/monitor"@en .

ict:Printer a rdfs:Class ;
    rdfs:subClassOf ict:Peripheral ;
    rdfs:label "Printer"@en, "Skriver"@no ;
    rdfs:comment "Printer"@en .

# ===================================================================
# Software subcategories
# ===================================================================

ict:Application a rdfs:Class ;
    rdfs:subClassOf ict:Software ;
    rdfs:label "Application"@en, "Applikasjon"@no ;
    rdfs:comment "Software application"@en .

ict:OperatingSystem a rdfs:Class ;
    rdfs:subClassOf ict:Software ;
    rdfs:label "Operating System"@en, "Operativsystem"@no ;
    rdfs:comment "Operating system software"@en .

ict:SoftwareLicense a rdfs:Class ;
    rdfs:subClassOf ict:Software ;
    rdfs:label "Software License"@en, "Programvarelisens"@no ;
    rdfs:comment "A software license or subscription held as an asset"@en .

# ===================================================================
# Property Definitions - Hardware + Software (shared)
# ===================================================================

ict:manufacturer a rdf:Property ;
    rdfs:label "Manufacturer"@en, "Produsent"@no ;
    skos:altLabel "Vendor"@en ;
    schema:domainIncludes ict:Hardware ;
    schema:domainIncludes ict:Software ;
    rdfs:range common:Manufacturer .

ict:model a rdf:Property ;
    rdfs:label "Model"@en, "Modell"@no ;
    schema:domainIncludes ict:Hardware ;
    schema:domainIncludes ict:Software ;
    rdfs:range common:Model .

ict:purchaseDate a rdf:Property ;
    rdfs:label "Purchase Date"@en, "Kjøpsdato"@no ;
    schema:domainIncludes ict:Hardware ;
    schema:domainIncludes ict:Software ;
    rdfs:range xsd:date .

# ===================================================================
# Property Definitions - Hardware specific
# ===================================================================

ict:serialNumber a rdf:Property ;
    rdfs:label "Serial Number"@en, "Serienummer"@no ;
    rdfs:domain ict:Hardware ;
    rdfs:range xsd:string .

ict:warrantyExpiry a rdf:Property ;
    rdfs:label "Warranty Expiry"@en, "Garanti utløper"@no ;
    rdfs:domain ict:Hardware ;
    rdfs:range xsd:date .

# Networks this hardware belongs to. Multi-valued reference into the logical
# ict:Network grouping — a device (router/switch/server/...) can be on many
# networks. Realized as the asset's category memberships (categoryIds) filtered
# to the ict:Network subtree.
ict:network a rdf:Property ;
    rdfs:label "Networks"@en, "Nettverk"@no ;
    rdfs:comment "Logical networks this hardware belongs to (multi-select of ict:Network categories)"@en ;
    rdfs:domain ict:Hardware ;
    rdfs:range ict:Network ;
    common:multiValued true .

# Computer specific
ict:operatingSystem a rdf:Property ;
    rdfs:label "Operating System"@en, "Operativsystem"@no ;
    rdfs:domain ict:Computer ;
    rdfs:range xsd:string .

ict:cpu a rdf:Property ;
    rdfs:label "CPU"@en, "Prosessor"@no ;
    rdfs:domain ict:Computer ;
    rdfs:range xsd:string .

ict:ramGb a rdf:Property ;
    rdfs:label "RAM (GB)"@en, "Minne (GB)"@no ;
    rdfs:domain ict:Computer ;
    rdfs:range xsd:integer .

ict:storageGb a rdf:Property ;
    rdfs:label "Storage (GB)"@en, "Lagring (GB)"@no ;
    rdfs:domain ict:Computer ;
    rdfs:range xsd:integer .

# Network equipment specific
ict:ipAddress a rdf:Property ;
    rdfs:label "IP Address"@en, "IP-adresse"@no ;
    rdfs:domain ict:NetworkEquipment ;
    rdfs:range xsd:string .

ict:macAddress a rdf:Property ;
    rdfs:label "MAC Address"@en, "MAC-adresse"@no ;
    rdfs:domain ict:NetworkEquipment ;
    rdfs:range xsd:string .

ict:portCount a rdf:Property ;
    rdfs:label "Port Count"@en, "Antall porter"@no ;
    rdfs:domain ict:NetworkEquipment ;
    rdfs:range xsd:integer .

# ===================================================================
# Property Definitions - Software specific
# ===================================================================

ict:version a rdf:Property ;
    rdfs:label "Version"@en, "Versjon"@no ;
    rdfs:domain ict:Software ;
    rdfs:range xsd:string .

ict:licenseCount a rdf:Property ;
    rdfs:label "License Count"@en, "Antall lisenser"@no ;
    rdfs:domain ict:Software ;
    rdfs:range xsd:integer .

ict:licenseExpiry a rdf:Property ;
    rdfs:label "License Expiry"@en, "Lisens utløper"@no ;
    rdfs:domain ict:Software ;
    rdfs:range xsd:date .

# ===================================================================
# Property Definitions - Network (logical grouping) specific
# ===================================================================

ict:cidr a rdf:Property ;
    rdfs:label "CIDR"@en, "CIDR"@no ;
    rdfs:comment "Network address range in CIDR notation, e.g. 10.0.1.0/24"@en ;
    rdfs:domain ict:Network ;
    rdfs:range xsd:string .

ict:vlanId a rdf:Property ;
    rdfs:label "VLAN ID"@en, "VLAN-ID"@no ;
    rdfs:domain ict:Network ;
    rdfs:range xsd:integer .

ict:gateway a rdf:Property ;
    rdfs:label "Gateway"@en, "Gateway"@no ;
    rdfs:domain ict:Network ;
    rdfs:range xsd:string .

# ===================================================================
# Cross-cutting property domain extensions
#
# Opt hardware and software into the common per-year asset valuation
# (formuesverdi). The property + range marker live in common-taxonomy.
# ===================================================================

common:assetValue schema:domainIncludes ict:Hardware .
common:assetValue schema:domainIncludes ict:Software .
